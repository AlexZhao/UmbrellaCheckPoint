+
+static inline void *prepare_digest_buffer(struct file *elf_file, int *buf_len)
+{
+	int ret = 0;
+	void *data_ptr = NULL;
+	void *buf = NULL;
+	struct elfhdr *ehdr = kzalloc(sizeof(struct elfhdr), GFP_KERNEL);
+	if (!ehdr) {
+		return NULL;
+	}
+
+	ret = elf_read(elf_file, ehdr, sizeof(struct elfhdr), 0);
+	if (ret < 0)
+		goto err_free;
+
+	*buf_len = sizeof(struct elfhdr) + ehdr->e_phentsize * ehdr->e_phnum +
+	               ehdr->e_shentsize * ehdr->e_shnum;
+
+	buf = kzalloc(*buf_len, GFP_KERNEL);
+	if (!buf)
+		goto err_free;
+
+	data_ptr = buf;
+	memcpy(data_ptr, ehdr, sizeof(struct elfhdr));
+	data_ptr += sizeof(struct elfhdr);
+
+	ret = elf_read(elf_file, data_ptr, ehdr->e_phentsize * ehdr->e_phnum, ehdr->e_phoff);
+	if (ret < 0)
+		goto err_free;
+        
+	data_ptr += ehdr->e_phentsize * ehdr->e_phnum;
+
+	ret = elf_read(elf_file, data_ptr, ehdr->e_shentsize * ehdr->e_shnum, ehdr->e_shoff);
+	if (ret < 0)
+		goto err_free;
+
+	kfree(ehdr);
+
+	return buf;
+
+err_free:
+	if (buf)
+		kfree(buf);
+
+	if (ehdr)
+		kfree(ehdr);
+
+	return NULL;
+}
+
+#ifdef DEBUG_ELF_SIGN
+static void dump_data(void *buffer, int buf_len) {
+	pr_debug("------ digested target hdrs %d ------ :", buf_len);
+	print_hex_dump(KERN_INFO, "", DUMP_PREFIX_ADDRESS, 16, 1, buffer, buf_len, false);
+}
+
+static void dump_digest(void *digest, int digest_size) {
+	pr_debug("------ digest data %d ------ :", digest_size);
+	print_hex_dump(KERN_INFO, "", DUMP_PREFIX_ADDRESS, 16, 1, digest, digest_size, false);
+}
+
+static void dump_signature(void *signature, int signature_len) {
+	pr_debug("------ signature data %d ------ :", signature_len);
+	print_hex_dump(KERN_INFO, "", DUMP_PREFIX_ADDRESS, 16, 1, signature, signature_len, false);
+}
+#endif
