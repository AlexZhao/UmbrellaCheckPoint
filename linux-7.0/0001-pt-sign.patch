+struct link_verify_notification {
+	int op_code;
+	char *link_str;
+};
+
+/* Notification of the Dynamic Linking Procedure When failed invoke this */
+static int arch_link_verify(unsigned long arg) {
+	int ret = -EINVAL;
+	char *link_str = NULL;
+	int len = 0;
+	struct link_verify_notification notify;
+
+	if (copy_from_user(&notify, (void *)arg, sizeof(notify))) {
+		pr_err("not able to copy the parameter from dynamic linker, but trigger verify, direct hang it");
+		goto hang;
+	}
+
+	len = strnlen_user((const char *)notify.link_str, MAXIMUM_ARCH_STR_LEN);
+	link_str = kzalloc(len, GFP_KERNEL);
+	if (!link_str) {
+		pr_err("not able to alloc memory for the loaded share lib, direct hang it");
+		goto hang;
+	}
+
+	if (strncpy_from_user(link_str, (const char *)notify.link_str, len) < 0) {
+		pr_err("not able to copy the link_str from userspace, direct hang it");
+		goto err;
+	}
+
+	ret = security_arch_link_elf_sign(notify.op_code, link_str);
+	if (ret)
+		goto err;
+    else
+		if (notify.op_code == 1)
+			pr_err("dynamic linking signature verification failed   -- > %s\n", link_str);
+		else
+			pr_err("dynamic linking not have signature -- > %s\n", link_str);
+
+err:
+	if (link_str)
+		kfree(link_str);
+
+hang:
+	if (ret)
+		do_exit(SIGKILL);
+		/* No Return */
+
+	return ret;
+}
+#endif
