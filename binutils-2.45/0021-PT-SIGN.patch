diff --git a/binutils/elfsign.c b/binutils/elfsign.c
new file mode 100644
index 00000000000..8639e3d71c9
--- /dev/null
+++ b/binutils/elfsign.c
@@ -0,0 +1,651 @@
+/* elfsign.c -- generate signature of the ELF save it to PT_SIGN program header
+   Copyright (C) 2010-2025 Free Software Foundation, Inc.
+
+   Author: Alex Zhao, zhe.alex.zhao@gmail.com
+   only sign the headers of the executable files
+   consider it is fast during dynamic loading, and modify executable
+   without modify its headers normally will break the dynamic loading
+ */
+#include <stdlib.h>
+#include <stdio.h>
+#include <unistd.h>
+#include <getopt.h>
+#include <sys/types.h>
+
+#include <openssl/evp.h>
+#include <openssl/pem.h>
+
+//#define DIGEST_DUMP
+
+#define SIGNATURE_LEN 256
+
+#define EI_NIDENT 16
+typedef u_int16_t Elf64_Half;
+typedef u_int32_t Elf64_Word;
+typedef u_int64_t Elf64_Addr;
+typedef u_int64_t Elf64_Off;
+typedef u_int64_t Elf64_Xword;
+typedef u_int64_t Elf64_Sxword;
+
+typedef u_int16_t Elf32_Half;
+typedef u_int32_t Elf32_Word;
+typedef u_int32_t Elf32_Addr;
+typedef u_int32_t Elf32_Off;
+typedef u_int32_t Elf32_Xword;
+typedef u_int32_t Elf32_Sxword;
+
+#define ET_NONE   0
+#define ET_REL    1
+// Only support below types signature
+#define ET_EXEC   2
+#define ET_DYN    3
+// No signature required
+#define ET_CORE   4
+#define ET_LOOS   0xfe00
+#define ET_HIOS   0xfeff
+#define ET_LOPROC 0xff00
+#define ET_HIPROC 0xffff
+
+// e_ident[EI_idx]
+#define EI_MAG0        0
+#define EI_MAG1        1
+#define EI_MAG2        2
+#define EI_MAG3        3
+#define EI_CLASS       4
+#define EI_DATA        5
+#define EI_VERSION     6
+#define EI_OSABI       7
+#define EI_ABIVERSION  8
+#define EI_PAD         9
+#define EI_NIDENT     16
+
+#define ELFCLASSNONE  0
+#define ELFCLASS32    1
+#define ELFCLASS64    2
+
+#define ELFDATANONE   0
+#define ELFDATA2LSB   1
+#define ELFDATA2MSB   2
+
+#define PT_SIGN 0x10000000
+
+typedef struct {
+        unsigned char e_ident[EI_NIDENT];
+} Elf_Ehdr;
+
+typedef struct {
+        unsigned char e_ident[EI_NIDENT];
+        Elf64_Half e_type;
+        Elf64_Half e_machine;
+        Elf64_Word e_version;
+        Elf64_Addr e_entry;
+        Elf64_Off e_phoff;
+        Elf64_Off e_shoff;
+        Elf64_Word e_flags;
+        Elf64_Half e_ehsize;
+        Elf64_Half e_phentsize;
+        Elf64_Half e_phnum;
+        Elf64_Half e_shentsize;
+        Elf64_Half e_shnum;
+        Elf64_Half e_shstrndx;
+} Elf64_Ehdr;
+
+typedef struct {
+        Elf64_Word p_type;
+        Elf64_Word p_flags;
+        Elf64_Off p_offset;
+        Elf64_Addr p_vaddr;
+        Elf64_Addr p_paddr;
+        Elf64_Xword p_filesz;
+        Elf64_Xword p_memsz;
+        Elf64_Xword p_align;
+} Elf64_Phdr;
+
+typedef struct {
+        Elf64_Word sh_name;
+        Elf64_Word sh_type;
+        Elf64_Xword sh_flags;
+        Elf64_Addr sh_addr;
+        Elf64_Off sh_offset;
+        Elf64_Xword sh_size;
+        Elf64_Word sh_link;
+        Elf64_Word sh_info;
+        Elf64_Xword sh_addralign;
+        Elf64_Xword sh_entsize;
+} Elf64_Shdr;
+
+typedef struct {
+        unsigned char e_ident[EI_NIDENT];
+        Elf32_Half e_type;
+        Elf32_Half e_machine;
+        Elf32_Word e_version;
+        Elf32_Addr e_entry;
+        Elf32_Off e_phoff;
+        Elf32_Off e_shoff;
+        Elf32_Word e_flags;
+        Elf32_Half e_ehsize;
+        Elf32_Half e_phentsize;
+        Elf32_Half e_phnum;
+        Elf32_Half e_shentsize;
+        Elf32_Half e_shnum;
+        Elf32_Half e_shstrndx;
+} Elf32_Ehdr;
+
+typedef struct {
+        Elf32_Word sh_name;
+        Elf32_Word sh_type;
+        Elf32_Word sh_flags;
+        Elf32_Addr sh_addr;
+        Elf32_Off sh_offset;
+        Elf32_Word sh_size;
+        Elf32_Word sh_link;
+        Elf32_Word sh_info;
+        Elf32_Word sh_addralign;
+        Elf32_Word sh_entsize;
+} Elf32_Shdr;
+
+typedef struct {
+        Elf32_Word p_type;
+        Elf32_Off p_offset;
+        Elf32_Addr p_vaddr;
+        Elf32_Addr p_paddr;
+        Elf32_Word p_filesz;
+        Elf32_Word p_memsz;
+        Elf32_Word p_flags;
+        Elf32_Word p_align;
+} Elf32_Phdr;
+
+#define MAX_FILE_NAME_LEN 4096
+
+static char *program_name = NULL;
+static int is_32_bit = 0;
+
+static int 
+digest_hdr_buffer_len(int phdr_num, int shdr_num) 
+{
+  /* digest contents include ELF HEADER, all Program Headers and all Section Headers */
+  if (is_32_bit)
+    return sizeof(Elf32_Ehdr) + phdr_num * sizeof(Elf32_Phdr) + shdr_num * sizeof(Elf32_Shdr);
+  else
+    return sizeof(Elf64_Ehdr) + phdr_num * sizeof(Elf64_Phdr) + shdr_num * sizeof(Elf64_Shdr);
+}
+
+/*
+ * Copy and arrange the contents need to be signed within single buffer
+ */
+static int
+prepare_digest_buffer (FILE *input, Elf64_Ehdr *ehdr, void *buffer)
+{
+  char *phdrs = (char *)buffer + sizeof(Elf64_Ehdr);
+  char *shdrs = (char *)buffer + sizeof(Elf64_Ehdr) + ehdr->e_phnum * sizeof(Elf64_Phdr);
+
+  if ((fseek (input, 0, SEEK_SET) != 0) || (fread (buffer, 1, sizeof(Elf64_Ehdr), input) != sizeof(Elf64_Ehdr)))
+    return -1;
+  if ((fseek (input, ehdr->e_phoff, SEEK_SET) != 0) || (fread (phdrs, 1, ehdr->e_phnum * sizeof(Elf64_Phdr), input) != ehdr->e_phnum * sizeof(Elf64_Phdr)))
+    return -1;
+  if ((fseek (input, ehdr->e_shoff, SEEK_SET) != 0) || (fread (shdrs, 1, ehdr->e_shnum * sizeof(Elf64_Shdr), input) != ehdr->e_shnum * sizeof(Elf64_Shdr)))
+    return -1;
+
+  return 0;
+}
+
+#ifdef DIGEST_DUMP
+static void 
+dump_digest_content (void *buffer, int buf_len)
+{
+  unsigned char *ptr = (unsigned char *)buffer;
+
+  printf("digested target hdrs %d:", buf_len);
+  for (int i = 0; i < buf_len; i++)
+    {
+      if (i % 16 == 0)
+        printf("\n");
+      printf("%02x ", ptr[i]);
+      if ((i+1) % 8 == 0)
+        printf(" ");
+    }
+    printf("\n");
+}
+
+static void
+dump_digest (void *digest, int digest_len)
+{
+  printf ("------ digest of the content -----\n");
+  unsigned char *ptr = (unsigned char *)digest;
+  for (int i = 0; i < digest_len; i++)
+    {
+      if (i % 16 == 0)
+        printf("\n");
+      printf("%02x ", ptr[i]);
+      if ((i+1) % 8 == 0)
+        printf(" ");
+    }
+    printf("\n");
+}
+
+
+static void
+dump_signature (void *signature, int sig_len)
+{
+  printf ("------ signature of the digest -----\n");
+  unsigned char *ptr = (unsigned char *)signature;
+  for (int i = 0; i < sig_len; i++)
+    {
+      if (i % 16 == 0)
+        printf("\n");
+      printf("%02x ", ptr[i]);
+      if ((i+1) % 8 == 0)
+        printf(" ");
+    }
+    printf("\n");
+
+}
+#endif
+
+#define SHA256_DIGEST_LEN 32
+#define SIGNATURE_LEN 256
+#define BUFFER_SIZE 4096
+
+/*
+ * Calculate PT_SIGN section of ELF binary
+ * Copy data from OpenSSL allocated data to xmalloc data
+ */
+static int 
+calculate_sign_section (FILE *input, Elf64_Ehdr *ehdr, void *signature, size_t len, const char *priv_key)
+{  
+  EVP_MD_CTX *ctx = NULL;
+  EVP_PKEY *pkey = NULL;
+  EVP_PKEY_CTX *pctx = NULL;
+  
+  unsigned int digest_len = 0;
+  FILE *key = NULL;
+  int ret = 1;
+  void *tmp = NULL;
+  void *digest = NULL;
+
+  if (ehdr == NULL)
+    goto err;
+ 
+  int phdr_num = ehdr->e_phnum;
+  int shdr_num = ehdr->e_shnum;
+    
+  int buf_len = digest_hdr_buffer_len (phdr_num, shdr_num);
+  void *buffer = malloc (buf_len);
+  if (!buffer)
+    goto err;
+
+  if (prepare_digest_buffer (input, ehdr, buffer))
+    goto err_close_key;
+
+  key = fopen(priv_key, "r");
+  if (key == NULL)
+    goto err_close_key;
+
+  pkey = PEM_read_PrivateKey (key, NULL, NULL, NULL);
+  if (pkey == NULL)
+    goto err_close_key;
+
+  ctx = EVP_MD_CTX_new ();
+  if (ctx == NULL)
+    goto err_close_key;
+
+  if (EVP_DigestInit (ctx, EVP_sha256()) == 0)
+    goto err_free_ctx;
+
+  if (EVP_DigestUpdate (ctx, buffer, buf_len) == 0)
+    goto err_free_ctx;
+
+#ifdef DIGEST_DUMP
+  dump_digest_content (buffer, buf_len);
+#endif
+
+  digest = OPENSSL_malloc (SHA256_DIGEST_LEN);
+  if (digest == NULL)
+    goto err_free_ctx;
+
+  if (EVP_DigestFinal (ctx, digest, &digest_len) == 0)
+    goto err_free_ctx;
+
+#ifdef DIGEST_DUMP
+  dump_digest (digest, digest_len);
+#endif
+
+  pctx = EVP_PKEY_CTX_new (pkey, NULL);
+  if (!pctx)
+    goto err_free_ctx;
+
+  size_t sig_len = 0;
+  if (EVP_PKEY_sign_init (pctx) <= 0)
+    goto err_free_ctx;
+
+  if (EVP_PKEY_CTX_set_rsa_padding (pctx, RSA_PKCS1_PADDING) <= 0)
+    goto err_free_ctx;
+
+  if (EVP_PKEY_CTX_set_signature_md (pctx, EVP_sha256 ()) <= 0)
+    goto err_free_ctx;
+
+  if (EVP_PKEY_sign (pctx, NULL, &sig_len, digest, digest_len) <= 0)
+    goto err_free_ctx;
+
+  tmp = OPENSSL_malloc (sig_len);
+  if (tmp == NULL)
+    goto err_free_ctx;
+
+  if (EVP_PKEY_sign (pctx, tmp, &sig_len, digest, digest_len) <= 0)
+    goto err_free_ctx;
+
+  if (len != sig_len)
+    goto err_free_ctx;
+  
+  memcpy (signature, tmp, sig_len);
+
+#ifdef DIGEST_DUMP
+  dump_signature (signature, sig_len);
+#endif
+
+  ret = 0;
+
+err_free_ctx:
+  if (tmp)
+    OPENSSL_free (tmp);
+
+  if (pctx)
+    EVP_PKEY_CTX_free (pctx);
+
+  if (digest)
+    OPENSSL_free (digest);
+
+  if (ctx)
+    EVP_MD_CTX_free (ctx);
+
+
+err_close_key:
+  if (pkey)
+    OPENSSL_free (pkey);
+
+  if (buffer)
+    free (buffer);
+
+
+  if (key)
+    fclose (key);
+
+err:
+  return ret;
+}
+
+/*
+ * This is no needed
+ * after linker can generate signature section
+ * direct use file open and sign will work, no BFD relevant modification required
+ */
+static int 
+sign_file (const char *input_elf, const char *private_key, const char *output_elf)
+{
+  FILE *input = NULL;
+  FILE *output = NULL;
+  char *signature = NULL;
+  char *tmp_elf = NULL;
+  char *buffer = NULL;
+  Elf64_Phdr *phdrs = NULL, *phdr = NULL;
+  size_t read_size = 0;
+  int success = 1;
+
+  input = fopen (input_elf, "r");
+  if (input == NULL)
+    goto err;
+
+  Elf64_Ehdr ehdr;
+  size_t read_len = fread (&ehdr, 1, sizeof(Elf64_Ehdr), input);
+  if (read_len != sizeof(Elf64_Ehdr))
+    goto err;
+
+  if (ehdr.e_type != ET_EXEC && ehdr.e_type != ET_DYN) 
+    {
+      printf ("elfsign not support other object file than ELF executable or Shared library\n");
+      fclose(input);
+      goto err;
+    }
+
+  if (ehdr.e_ident[EI_CLASS] != ELFCLASS64) 
+    {
+      printf ("elfsign only support 64bit ELF file");
+      fclose(input);
+      goto err;
+    }
+
+  // Modify to support big endian ELF file
+  if (ehdr.e_ident[EI_DATA] != ELFDATA2LSB)
+    {
+      printf ("elfsign only support little endian ELF file");
+      fclose(input);
+      goto err;
+    }
+
+#ifdef DEBUG_ELFSIGN
+  printf ("Elf Data type %d, entry 0x%lx phdr offset 0x%lx phdr cnt %d, shdr offset 0x%lx shdr cnt %d\n", 
+              ehdr.e_type, ehdr.e_entry, ehdr.e_phoff, ehdr.e_phnum, ehdr.e_shoff, ehdr.e_shnum);
+#endif
+    
+  phdrs = malloc (sizeof (Elf64_Phdr) * ehdr.e_phnum);
+  if (phdrs == NULL) 
+    {
+      fclose (input);
+      goto err;
+    }
+
+  phdr = phdrs;
+  read_size = fread (phdrs, 1, sizeof (Elf64_Phdr) * ehdr.e_phnum, input);
+  if (read_size != (sizeof (Elf64_Phdr) * ehdr.e_phnum))
+    {
+      fclose (input);
+      goto err;
+    }
+
+  for (int i = 0; i < ehdr.e_phnum; i++) 
+    {
+      if (phdr->p_type == PT_SIGN) 
+        {
+          goto calc;
+        }
+      phdr++;
+    }
+
+  success = 2;
+
+  goto err;
+
+calc:
+
+  signature = malloc (SIGNATURE_LEN);
+  if (signature == NULL)
+    {
+      fclose(input);
+      goto err;
+    }
+
+  memset (signature, 0, SIGNATURE_LEN);
+
+  if (calculate_sign_section (input, &ehdr, signature, SIGNATURE_LEN, private_key))
+    {
+      fclose (input);
+      goto err;
+    }
+
+  tmp_elf = malloc (MAX_FILE_NAME_LEN);
+  if (tmp_elf == NULL)
+    {
+      fclose(input);
+      goto err;
+    }
+  memset (tmp_elf, 0, MAX_FILE_NAME_LEN);
+
+  snprintf (tmp_elf, MAX_FILE_NAME_LEN, "%s.tmp", output_elf);
+  output = fopen(tmp_elf, "w+");
+  if (output == NULL)
+    {
+      fclose(input);
+      goto err;
+    }
+
+  if (fseek(output, 0, SEEK_SET) !=0 || fseek(input, 0, SEEK_SET) != 0)
+    {
+      fclose(input);
+      fclose(output);
+      goto err;
+    }
+
+  buffer = malloc (BUFFER_SIZE);
+  if (buffer == NULL)
+    {
+      fclose(input);
+      fclose(output);
+      goto err;
+    }
+
+  while ((read_size = fread(buffer, 1, sizeof(buffer), input)) > 0) 
+    {
+      fwrite(buffer, 1, read_size, output);
+    }
+
+  fclose(input);
+
+  fseek(output, 0, SEEK_SET);
+  if (fread(&ehdr, 1, sizeof(Elf64_Ehdr), output) != sizeof(Elf64_Ehdr))
+    {
+      fclose(output);
+      goto err;
+    }
+
+  if (fseek(output, ehdr.e_phoff, SEEK_SET) != 0)
+    {
+      fclose(output);
+      goto err;
+    }
+
+  if (fread(phdrs, 1, sizeof(Elf64_Phdr) * ehdr.e_phnum, output) != (sizeof(Elf64_Phdr) * ehdr.e_phnum))
+    {
+      fclose(output);
+      goto err;
+    }
+    
+  phdr = phdrs;
+  for (int i = 0; i < ehdr.e_phnum; i++) 
+    {
+      if (phdr->p_type == PT_SIGN) 
+        {
+          fseek(output, phdr->p_offset, SEEK_SET);
+          fwrite(signature, 1, SIGNATURE_LEN, output);
+#ifdef DEBUG_ELFSIGN
+          printf ("update signature section, offset 0x%lx, size 0x%lx\n", phdr->p_offset, phdr->p_filesz);
+#endif
+          break;
+        }
+      phdr++;
+    }
+
+  fclose(output);
+
+  input = fopen(tmp_elf, "r");
+  if (input == NULL)
+    {
+      goto err;
+    }
+
+  output = fopen(output_elf, "w");
+  if (output == NULL)
+    {
+      fclose(input);
+      goto err;
+    }
+
+  while ((read_size = fread(buffer, 1, sizeof(buffer), input)) > 0) 
+    {
+      fwrite(buffer, 1, read_size, output);
+    }
+
+  fclose(input);
+  if (remove(tmp_elf))
+    {
+      printf("remove tmp file %s failed\n", tmp_elf);
+    }
+
+  fclose(output);
+
+  success = 0;
+
+err:
+  if (signature)
+    free (signature);
+
+  if (tmp_elf)
+    free (tmp_elf);
+
+  return success;
+}
+
+#define OPTION_PRIVATE_KEY 1
+#define OPTION_INPUT 2
+#define OPTION_OUTPUT 3
+
+struct option options[] = {
+    {"private-key", required_argument, NULL, OPTION_PRIVATE_KEY},
+    {"input", required_argument, NULL, OPTION_INPUT},
+    {"output", required_argument, NULL, OPTION_OUTPUT},
+    {0, 0, 0, 0}
+};
+
+//
+// Need to modify the ld 
+// the within ELF offset will be changed when add PT_SIGN with program header
+// may only use .signature section to store the signature, without buffer it at program header
+// This maybe simpler than modify linker
+//
+// Configure specific os relevant phdrs PT_SIGN to have the PT_SIGN configured during linking
+// phase, and use elfsign to regenerate the signature without impact the offset
+// This should works
+//
+int main(int argc, char *argv[])
+{
+  int c, status;
+  char *input_elf = NULL;
+  char *output_elf = NULL;
+  char *private_key = NULL;
+
+  /* Set elfsign name */
+  program_name = argv[0];
+
+  while ((c = getopt_long (argc, argv, "hv", options, (int *) 0)) != EOF) 
+    {
+      switch (c) {
+        case OPTION_PRIVATE_KEY:
+          private_key = optarg;
+          break;
+        case OPTION_INPUT:
+          input_elf = optarg;
+          break;
+        case OPTION_OUTPUT:
+          output_elf = optarg;
+          break;
+        default:
+          break;
+      }
+    }
+
+  if (output_elf == NULL)
+    output_elf = input_elf;
+
+  if (input_elf == NULL || output_elf == NULL || private_key == NULL) 
+    {
+      printf("Not correct parameter require to have --input <file> --private_key <key> --output <file>\n");
+      status = -1;
+      return status;
+    }
+
+  status = sign_file (input_elf, private_key, output_elf);
+  if (status)
+    printf("Failed sign ELF %s with private key %s\n", input_elf, private_key);
+
+  return status;
+}
