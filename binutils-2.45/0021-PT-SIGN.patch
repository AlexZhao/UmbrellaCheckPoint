     case PT_GNU_RELRO: pt = "RELRO"; break;
@@ -3113,6 +3114,7 @@ static const struct bfd_elf_special_section special_sections_s[] =
   /* See struct bfd_elf_special_section declaration for the semantics of
      this special case where .prefix_length != strlen (.prefix).  */
   { ".stabstr",			5,  3, SHT_STRTAB, 0 },
+  { STRING_COMMA_LEN (".signature"),0, SHT_PROGBITS, SHF_ALLOC },
   { NULL,			0,  0, 0,	   0 }
 };
 
@@ -3432,6 +3434,9 @@ bfd_section_from_phdr (bfd *abfd, Elf_Internal_Phdr *hdr, int hdr_index)
     case PT_PHDR:
       return _bfd_elf_make_section_from_phdr (abfd, hdr, hdr_index, "phdr");
 
+    case PT_SIGN:
+      return _bfd_elf_make_section_from_phdr (abfd, hdr, hdr_index, "signature");
+
     case PT_GNU_EH_FRAME:
       return _bfd_elf_make_section_from_phdr (abfd, hdr, hdr_index,
 					      "eh_frame_hdr");
@@ -4730,6 +4735,12 @@ _bfd_elf_compute_section_file_positions (bfd *abfd,
   return false;
 }
 
+static asection *
+elf_eh_signature_hdr (struct bfd *abfd)
+{
+  return bfd_get_section_by_name (abfd, ".signature");
+}
+
 /* Retrieve .eh_frame_hdr.  Prior to size_dynamic_sections the
    function effectively returns whether --eh-frame-hdr is given on the
    command line.  After size_dynamic_sections the result reflects
@@ -4780,6 +4791,12 @@ get_program_header_size (bfd *abfd, struct bfd_link_info *info)
       ++segs;
     }
 
+  if (elf_eh_signature_hdr (abfd) != NULL)
+    {
+       /* We need a PG_SIGN segment */
+       ++segs;
+    }
+
   if (elf_eh_frame_hdr (info))
     {
       /* We need a PT_GNU_EH_FRAME segment.  */
@@ -5062,7 +5079,7 @@ _bfd_elf_map_sections_to_segments (bfd *abfd,
       unsigned int tls_count = 0;
       asection *first_tls = NULL;
       asection *first_mbind = NULL;
-      asection *dynsec, *eh_frame_hdr;
+      asection *dynsec, *eh_signature_hdr, *eh_frame_hdr;
       asection *sframe;
       size_t amt;
       bfd_vma addr_mask, wrap_to = 0;  /* Bytes.  */
@@ -5542,6 +5559,30 @@ _bfd_elf_map_sections_to_segments (bfd *abfd,
 	  pm = &m->next;
 	}
 
+      /* Always throw in .signature and throw in a  PT_SIGN segment */
+      eh_signature_hdr = elf_eh_signature_hdr (abfd);
+      if (eh_signature_hdr != NULL && eh_signature_hdr->size != 0)
+	{
+	  amt = sizeof (struct elf_segment_map) + sizeof (asection *);
+	  m = (struct elf_segment_map *) bfd_zalloc (abfd, amt);
+	  if (m == NULL)
+	    goto error_return;
+	  m->next = NULL;
+	  m->p_type = PT_SIGN;
+	  m->count = 1;
+	  m->p_flags_valid = 1;
+	  m->sections[0] = eh_signature_hdr;
+	  m->p_flags = PF_R;
+	  m->p_align = 4;
+	  m->p_align_valid = 1;
+
+	  // modify .signature attribute here is not a good idea
+	  eh_signature_hdr->output_section->flags |= SEC_LOAD;
+
+	  *pm = m;
+	  pm = &m->next;
+	}
+
       /* If there is a .eh_frame_hdr section, throw in a PT_GNU_EH_FRAME
 	 segment.  */
       eh_frame_hdr = elf_eh_frame_hdr (info);
